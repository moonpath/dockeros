#!/bin/bash
set -euo pipefail

: ${NOVNC_IP:=""}
: ${NOVNC_PORT:=7900}
: ${NOVNC_DOMAIN:=_}
: ${NOVNC_SUBFOLDER:=/}
: ${NOVNC_USER:=user}
: ${NOVNC_PASSWORD:=password}
: ${NOVNC_AUTH:=false}
: ${NAME:=$NOVNC_USER}
: ${MAIN:=/home/$NAME}

mkdir -p /etc/s6-overlay/s6-rc.d/vncserver/env
printf "%s" "$NAME" > /etc/s6-overlay/s6-rc.d/vncserver/env/USER
printf "%s" "$MAIN" > /etc/s6-overlay/s6-rc.d/vncserver/env/HOME
printf "%s" "$NOVNC_IP" > /etc/s6-overlay/s6-rc.d/vncserver/env/NOVNC_IP
printf "%s" "$NOVNC_PORT" > /etc/s6-overlay/s6-rc.d/vncserver/env/NOVNC_PORT

mkdir -p /etc/s6-overlay/s6-rc.d/pulseaudio/env
printf "%s" "$NAME" > /etc/s6-overlay/s6-rc.d/pulseaudio/env/USER
printf "%s" "$MAIN" > /etc/s6-overlay/s6-rc.d/pulseaudio/env/HOME
printf "%s" ":1" > /etc/s6-overlay/s6-rc.d/pulseaudio/env/DISPLAY

mkdir -p /etc/s6-overlay/s6-rc.d/kclient/env
printf "%s" "$NAME" > /etc/s6-overlay/s6-rc.d/kclient/env/USER
printf "%s" "$MAIN" > /etc/s6-overlay/s6-rc.d/kclient/env/HOME
printf "%s" "$NOVNC_SUBFOLDER" > /etc/s6-overlay/s6-rc.d/kclient/env/WEBSOCKIFY_SUBFOLDER

chown "$NAME":"$NAME" "$MAIN"

if [ -d "$MAIN" ] && [ -z "$(ls $MAIN)" ]; then
    cp --update=none /etc/skel/.bashrc /etc/skel/.profile /etc/skel/.bash_logout "$MAIN/"
    install -m 755 -d "$MAIN/Desktop"
    install -m 755 /usr/share/applications/code.desktop "$MAIN/Desktop/"
    install -m 755 /usr/share/applications/microsoft-edge.desktop "$MAIN/Desktop/"
    install -m 755 /usr/local/share/JetBrains/Toolbox/jetbrains-toolbox.desktop "$MAIN/Desktop/"
    chown -R "$NAME":"$NAME" "$MAIN"
fi

if [ ! -f "$MAIN/.kasmpasswd" ]; then
    echo -e "$NOVNC_PASSWORD\n$NOVNC_PASSWORD\n" | HOME="$MAIN" s6-setuidgid "$NAME" vncpasswd -u "$NOVNC_USER" -o -w -r
fi

if [ ! -f "/etc/nginx/sites-enabled/webos" ]; then
    sed -i "s/\$HTTP_PORT/$NOVNC_PORT/g" /etc/nginx/sites-available/webos
    sed -i "s/\$HTTPS_PORT/$((NOVNC_PORT+1))/g" /etc/nginx/sites-available/webos

    sed -i "s/\$DOMAIN/$NOVNC_DOMAIN/g" /etc/nginx/sites-available/webos

    sed -i "s#\$SUBFOLDER#$NOVNC_SUBFOLDER#g" /etc/nginx/sites-available/webos

    printf "$NOVNC_USER:$(openssl passwd -apr1 $NOVNC_PASSWORD)\n" | tee /etc/nginx/.htpasswd >>/dev/null
    sed -i "s/\$HTTP_BASIC_AUTH/$(echo -n "$NOVNC_USER:$NOVNC_PASSWORD" | base64)/g" /etc/nginx/sites-available/webos

    if [ "$NOVNC_AUTH" = "false" ]; then
        sed -i 's/auth_basic/#auth_basic/g' /etc/nginx/sites-available/webos
        sed -i 's/auth_basic_user_file/#auth_basic_user_file/g' /etc/nginx/sites-available/webos
    fi

    ln -s /etc/nginx/sites-available/webos /etc/nginx/sites-enabled/webos
fi
